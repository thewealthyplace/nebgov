# NebGov App Environment Variables
# Copy this file to .env.local and update with your contract addresses

# Governor contract address on Stellar
NEXT_PUBLIC_GOVERNOR_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# Timelock contract address on Stellar
NEXT_PUBLIC_TIMELOCK_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# Token Votes contract address on Stellar  
NEXT_PUBLIC_VOTES_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# Stellar network: mainnet, testnet, or futurenet
NEXT_PUBLIC_NETWORK=testnet

# Optional: Custom RPC URL (defaults to public endpoint if not set)
# NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
